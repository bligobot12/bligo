
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Real Connections, Curated by AI | Bligo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <meta property="og:title" content="Real Connections, Curated by AI" />
  <meta property="og:description" content="Unlock new connections across your personal network. Review intelligent matches and connect by mutual introduction." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://bligo.ai" />
  <meta property="og:image" content="https://bligo.ai/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Real Connections, Curated by AI" />
  <meta name="twitter:description" content="Unlock new connections across your personal network." />
  <meta name="twitter:image" content="https://bligo.ai/og-image.png" />
  <style>
    :root {
      color-scheme: dark;
      --bg: #05060a;
      --card: #0e1118;
      --primary: #68f0c4;
      --soft: #9ca3af;
      --white: #f8fafc;
      --border: rgba(255,255,255,0.08);
    }
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: radial-gradient(circle at top, rgba(104,240,196,0.08), transparent 45%), var(--bg);
      color: var(--white);
      line-height: 1.6;
      min-height: 100vh;
    }
    header {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(10px);
      background: rgba(5,6,10,0.72);
      border-bottom: 1px solid var(--border);
      padding: 16px 4vw;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .logo-image {
      height: 42px;
      width: auto;
      display: block;
      border-radius: 12px;
      border: 1px solid var(--border);
    }
    .header-actions {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .hero {
      padding: 60px 4vw 40px;
      display: grid;
      grid-template-columns: repeat(auto-fit,minmax(320px,1fr));
      gap: 32px;
      align-items: center;
    }
    .hero-media {
      display: flex;
      justify-content: center;
    }
    .hero-media-frame {
      width: min(100%, 430px);
      aspect-ratio: 1 / 1;
      border: 1px dashed var(--border);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .hero-media-frame img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
    h1 {
      font-size: clamp(2.6rem, 5vw, 3.6rem);
      line-height: 1.1;
      margin-bottom: 24px;
    }
    .hero p {
      color: var(--soft);
      font-size: 1.1rem;
      margin-bottom: 32px;
      max-width: 540px;
    }
    .cta-group {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
    }
    .btn {
      padding: 14px 26px;
      border-radius: 999px;
      border: none;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .btn-primary {
      background: linear-gradient(120deg, #68f0c4, #5b8dff);
      color: #05060a;
      box-shadow: 0 15px 35px rgba(91,141,255,0.3);
    }
    .btn-secondary {
      background: transparent;
      color: var(--white);
      border: 1px solid var(--border);
    }
    .btn:hover {
      transform: translateY(-2px);
    }
    section {
      padding: 60px 4vw;
    }
    h2 {
      font-size: 2rem;
      margin-bottom: 16px;
    }
    .section-subline {
      color: var(--soft);
      max-width: 560px;
      margin: -8px 0 24px;
    }
    .eyebrow {
      text-transform: uppercase;
      font-size: 0.85rem;
      letter-spacing: 0.12em;
      color: var(--soft);
      margin-bottom: 12px;
    }
    .grid-3 {
      display: grid;
      grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
      gap: 20px;
      margin-top: 32px;
    }
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 24px;
      min-height: 230px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 0.85rem;
      color: var(--primary);
    }
    .privacy {
      background: rgba(14,17,24,0.8);
      border: 1px solid var(--border);
      border-radius: 28px;
      display: grid;
      grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
      gap: 28px;
      align-items: center;
      padding: 40px;
    }
    .privacy ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .privacy li::before {
      content: '• ';
      color: var(--primary);
    }
    .waitlist {
      padding: 60px 4vw 80px;
      display: grid;
      grid-template-columns: repeat(auto-fit,minmax(320px,1fr));
      gap: 32px;
      align-items: center;
    }
    form {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 32px;
      display: flex;
      flex-direction: column;
      gap: 18px;
    }
    label {
      font-size: 0.95rem;
      font-weight: 500;
    }
    input, textarea {
      padding: 14px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.02);
      color: var(--white);
      font-size: 1rem;
    }
    footer {
      padding: 30px 4vw 50px;
      font-size: 0.9rem;
      color: var(--soft);
      border-top: 1px solid var(--border);
      text-align: center;
    }
    @media (max-width: 640px) {
      header, section, .waitlist, .hero {
        padding-left: 5vw;
        padding-right: 5vw;
      }
      .cta-group {
        flex-direction: column;
        width: 100%;
      }
      .btn {
        width: 100%;
        text-align: center;
      }
    }
  
    @media (max-width: 760px) {
      header { padding: 12px 4vw; }
      .logo-image { height: 34px; }
      .hero { padding: 34px 4vw 24px; grid-template-columns: 1fr; gap: 20px; }
      h1 { font-size: clamp(2rem, 9vw, 2.6rem); margin-bottom: 16px; }
      .hero p { font-size: 1rem; margin-bottom: 20px; }
      .cta-group { width: 100%; }
      .btn { width: 100%; text-align: center; }
      section { padding: 42px 4vw; }
      .privacy { padding: 22px; border-radius: 18px; }
      .waitlist { padding: 40px 4vw 64px; grid-template-columns: 1fr; }
      form { padding: 20px; border-radius: 16px; }
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">
      <img src="data:image/png;base64," alt="Bligo logo" class="logo-image" />
      <div>
        <strong>Bligo</strong>
        <div style="font-size:0.85rem;color:var(--soft)">AI-driven introductions</div>
      </div>
    </div>
    <div class="header-actions">
      <a href="/signin" class="btn btn-primary">Sign in</a>
      <a href="#waitlist" class="btn btn-secondary">Join Waitlist</a>
    </div>
  </header>

  <section class="hero">
    <div>
      <div class="eyebrow">Meet Bligo</div>
      <h1>Real connections, curated by AI.</h1>
      <p class="subhead">Your own smarter network.</p>
      <p>Bligo helps you unlock new connections across your personal network. Share your intent, and AI surfaces high-fit matches within your direct and extended circles. You approve the introduction, they accept, and a private conversation opens.</p>
      <div class="cta-group">
        <a href="#waitlist" class="btn btn-primary">Connect Your Personal AI</a>
      </div>
    </div>
    <div class="hero-media">
      <div class="hero-media-frame">
        <img src="/bot.png" alt="Bligo bot" />
      </div>
    </div>
  </section>

  <section id="how">
    <div class="eyebrow">How it works</div>
    <h2>Tell AI what you’re looking for.</h2>
    <p class="section-subline">Discover your best-fit connections.</p>
    <div class="grid-3">
      <div class="card">
        <div class="badge">01 · Activate</div>
        <h3>Set your intent</h3>
        <p>Create your profile, define your goals, and control exactly what’s visible and what stays private.</p>
      </div>
      <div class="card">
        <div class="badge">02 · Match</div>
        <h3>Review connections</h3>
        <p>AI identifies and ranks high-fit matches across your direct and extended network based on your intent.</p>
      </div>
      <div class="card">
        <div class="badge">03 · Introduce</div>
        <h3>Connect with consent</h3>
        <p>Approve the introduction, send a soft request, and converse only when the other person accepts.</p>
      </div>
    </div>
  </section>

  <section>
    <div class="eyebrow">Use cases</div>
    <h2>Built for real-world connections.</h2>
    <div class="grid-3">
      <div class="card">
        <div class="badge">Professional Introductions</div>
        <h3>Find the right expert.</h3>
        <p>Looking for a realtor, attorney, or contractor? Bligo surfaces trusted professionals within your network—friends-of-friends included—based on your exact needs and location. You review the match and open a soft introduction with confidence.</p>
      </div>
      <div class="card">
        <div class="badge">Shared Plans &amp; Hobbies</div>
        <h3>Discover who’s doing what you’re doing.</h3>
        <p>Planning a ski trip? Bligo can show you which connections are heading to the same place—giving you the option to coordinate or connect.</p>
      </div>
      <div class="card">
        <div class="badge">Meaningful New Connections</div>
        <h3>Meet people who genuinely align.</h3>
        <p>Love the same restaurants and music? Bligo highlights high-overlap introductions within your extended network so you can open a thoughtful conversation and see where it leads.</p>
      </div>
    </div>
  </section>

  <section class="privacy">
    <div>
      <div class="eyebrow">Privacy &amp; Safety</div>
      <h2>You stay in control.</h2>
      <p>Bligo is human-led and consent-based. Every data field is optional, every action is logged, and nothing moves forward unless you approve it.</p>
    </div>
    <ul>
      <li>Intent and privacy toggles for every data point.</li>
      <li>Audit trail of each approved introduction.</li>
      <li>Both sides must accept before a conversation opens.</li>
      <li>Private, permission-based conversations with explicit acceptance from both sides.</li>
    </ul>
  </section>

  <section>
    <div class="eyebrow">What's next</div>
    <h2>Built for trusted, high-signal intros.</h2>
    <div class="grid-3">
      <div class="card"><div class="badge">Q1</div><h3>Intent Profiles</h3><p>Fine-grained controls for what your AI can share publicly vs privately.</p></div>
      <div class="card"><div class="badge">Q2</div><h3>Trust Layer</h3><p>Mutual-consent intros with transparent reason codes for every match.</p></div>
      <div class="card"><div class="badge">Q3</div><h3>Operator Feed</h3><p>A live opportunity feed built from your preferences and trusted network graph.</p></div>
    </div>
  </section>

  <section class="waitlist" id="waitlist">
    <div>
      <div class="eyebrow">Join the waitlist</div>
      <h2>Lead with intent.</h2>
      <p>Early access includes guided onboarding, intent templates, and a private operator community. Spots are limited.</p>
    </div>
    <form id="waitlist-form">
      <label for="email">Email*</label>
      <input type="email" id="email" name="email" placeholder="you@company.com" required />
      <label for="role">Role / Specialty</label>
      <input type="text" id="role" name="role" placeholder="Developer, Operator, GC, Investor..." />
      <label for="needs">What should AI help you find?</label>
      <textarea id="needs" name="needs" rows="4" placeholder="Deal flow, project squads, casual meetups..."></textarea>
      <button type="submit" class="btn btn-primary" id="submit-btn">Save my spot</button>
      <p id="form-status" style="font-size:0.95rem;color:var(--soft)"></p>
    </form>
  </section>

  <footer>
    © <span id="year"></span> Bligo. Intent-driven introductions. · v1.002.002
  </footer>

  <script>
    const form = document.getElementById('waitlist-form');
    const statusEl = document.getElementById('form-status');
    const submitBtn = document.getElementById('submit-btn');
    if (form && statusEl && submitBtn) {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.7';
        statusEl.textContent = 'Sending...';
        try {
          const formData = new FormData(form);
          const res = await fetch('https://formsubmit.co/ajax/info@whiteplainspm.net', {
            method: 'POST',
            headers: { 'Accept': 'application/json' },
            body: formData
          });
          if (res.ok) {
            form.reset();
            statusEl.textContent = 'You are in. We'll reach out soon.';
          } else {
            statusEl.textContent = 'Submit failed. Email info@bligo.ai and we'll add you manually.';
          }
        } catch (err) {
          statusEl.textContent = 'Network issue. Email info@bligo.ai and we'll add you manually.';
        } finally {
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
        }
      });
    }
    const y = document.getElementById('year');
    if (y) y.textContent = new Date().getFullYear();
  </script>
</body>
</html>

